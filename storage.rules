rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function admin() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /products/{productId}/{fileName} {
      allow read: if true;
      allow write: if admin();
    }

    match /banners/{fileName} {
      allow read: if true;
      allow write: if admin();
    }

    match /member-documents/{uid}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == uid || admin());
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
